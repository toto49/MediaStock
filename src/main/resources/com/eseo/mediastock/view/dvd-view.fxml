<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import java.net.URL?>
<AnchorPane xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx"
            fx:controller="com.eseo.mediastock.controller.DVDController"
            prefHeight="600.0" prefWidth="900.0"
            style="-fx-background-color: #2b2b2b;">

    <stylesheets>
        <URL value="@../../../../style/menu-deroulant.css"/>
        <URL value="@../../../../style/tableview.css"/>
    </stylesheets>

    <HBox alignment="CENTER_LEFT" spacing="20"
          AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0">

        <Button text="RETOUR" onAction="#ButtonReturn"
                style="-fx-background-color: transparent; -fx-text-fill: #ffcc00; -fx-border-color: #ffcc00; -fx-border-radius: 30; -fx-border-width: 2; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 8 20;">
            <graphic>
                <SVGPath content="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" fill="#ffcc00"
                         scaleX="0.8" scaleY="0.8"/>
            </graphic>
        </Button>

        <Label text="Collection de DVD"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;">
            <effect>
                <DropShadow color="#00000066" radius="10" offsetY="3"/>
            </effect>
        </Label>

        <Region HBox.hgrow="ALWAYS" />

        <Button text="AJOUTER" onAction="#ButtonAjouter"
                style="-fx-background-color: transparent; -fx-text-fill: #ffcc00; -fx-border-color: #ffcc00; -fx-border-radius: 30; -fx-border-width: 2; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 8 20;">
            <graphic>
                <SVGPath content="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" fill="#ffcc00" scaleX="0.8" scaleY="0.8"/>
            </graphic>
        </Button>

    </HBox>

    <ScrollPane fitToHeight="true" fitToWidth="true"
                style="-fx-background-color: transparent; -fx-background: #2b2b2b; -fx-border-color: transparent; -fx-background-insets: 0; -fx-padding: 0;"
                AnchorPane.topAnchor="90.0" AnchorPane.bottomAnchor="20.0"
                AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <content>
            <VBox minWidth="950" spacing="0" alignment="TOP_CENTER"
                  style="-fx-background-color: #2b2b2b; -fx-padding: 0 20 0 20;">

                <VBox VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #383838; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 10, 0, 0, 5); -fx-padding: 10;">

                    <TableView fx:id="tableDVD" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-background-insets: 0;">

                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>

                        <columns>
                            <TableColumn text="#" fx:id="colId" minWidth="40" maxWidth="60"
                                         style="-fx-alignment: CENTER;">
                                <cellValueFactory>
                                    <PropertyValueFactory property="id"/>
                                </cellValueFactory>
                            </TableColumn>

                            <TableColumn text="Titre" fx:id="colTitre" prefWidth="200" style="-fx-font-weight: bold;">
                                <cellValueFactory>
                                    <PropertyValueFactory property="titre"/>
                                </cellValueFactory>
                            </TableColumn>

                            <TableColumn text="Réalisateur" fx:id="colRealisateur" prefWidth="150">
                                <cellValueFactory>
                                    <PropertyValueFactory property="realisateur"/>
                                </cellValueFactory>
                            </TableColumn>

                            <TableColumn text="Éditeur" fx:id="colEditeur" prefWidth="120">
                                <cellValueFactory>
                                    <PropertyValueFactory property="editeur"/>
                                </cellValueFactory>
                            </TableColumn>

                            <TableColumn text="Audio" fx:id="colLangues" prefWidth="120">
                                <cellValueFactory>
                                    <PropertyValueFactory property="audioLangues"/>
                                </cellValueFactory>
                            </TableColumn>

                            <TableColumn text="Sous-titres" fx:id="colSousTitres" prefWidth="120">
                                <cellValueFactory>
                                    <PropertyValueFactory property="sousTitres"/>
                                </cellValueFactory>
                            </TableColumn>

                            <TableColumn text="Année" fx:id="colAnnee" minWidth="60" maxWidth="80"
                                         style="-fx-alignment: CENTER;">
                                <cellValueFactory>
                                    <PropertyValueFactory property="anneeSortie"/>
                                </cellValueFactory>
                            </TableColumn>

                            <TableColumn text="Durée" fx:id="colDuree" minWidth="60" maxWidth="80"
                                         style="-fx-alignment: CENTER;">
                                <cellValueFactory>
                                    <PropertyValueFactory property="dureeMinutes"/>
                                </cellValueFactory>
                            </TableColumn>

                            <TableColumn fx:id="colAction" text="Actions" prefWidth="120" minWidth="120" maxWidth="150"
                                         style="-fx-alignment: CENTER;"/>
                        </columns>

                        <placeholder>
                            <VBox alignment="CENTER" spacing="10">
                                <ProgressIndicator fx:id="loadingIcon" prefWidth="40" prefHeight="40"/>
                                <Label fx:id="placeholderLabel" text="Recherche des DVD en cours..."
                                       style="-fx-text-fill: #888; -fx-font-size: 14px;"/>
                            </VBox>
                        </placeholder>

                    </TableView>

                    <Pagination fx:id="paginationDVD" maxPageIndicatorCount="5" pageCount="1"
                                style="-fx-padding: 10 0 0 0;"/>

                </VBox>
            </VBox>
        </content>
    </ScrollPane>


</AnchorPane>