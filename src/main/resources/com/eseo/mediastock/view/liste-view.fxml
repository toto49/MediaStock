<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.Group?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx"
            fx:controller="com.eseo.mediastock.controller.ListeViewController"
            stylesheets="@../../../../style/button.css"
            prefHeight="600.0" prefWidth="900.0"
            style="-fx-background-color: transparent;">

    <VBox alignment="CENTER" spacing="50"
          AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">

        <Label style="-fx-text-fill: #ffcc00; -fx-font-size: 32px; -fx-font-weight: bold;">
            Choisissez votre média
        </Label>

        <HBox alignment="CENTER" spacing="50">

            <Button onAction="#ButtonViewLivre" styleClass="card-button" contentDisplay="TOP" graphicTextGap="60">
                <graphic>
                    <Group>
                        <Rectangle width="90" height="100" arcWidth="30" arcHeight="30" fill="transparent"
                                   stroke="#ffcc00" strokeWidth="6" translateX="-10" translateY="-10"/>
                        <Rectangle width="90" height="100" arcWidth="30" arcHeight="30" fill="transparent"
                                   stroke="#ffcc00" strokeWidth="6" translateX="10" translateY="10"/>
                    </Group>
                </graphic>
                <text>Livre</text>
            </Button>

            <Button onAction="#ButtonViewJeux" styleClass="card-button" contentDisplay="TOP" graphicTextGap="60">
                <graphic>
                    <Group>
                        <Rectangle width="100" height="120" fill="transparent" stroke="#ffcc00" strokeWidth="6"/>
                    </Group>
                </graphic>
                <text>Jeu société</text>
            </Button>

            <Button onAction="#ButtonViewDVD" styleClass="card-button" contentDisplay="TOP" graphicTextGap="60">
                <graphic>
                    <Group>
                        <Circle radius="60" fill="transparent" stroke="#ffcc00" strokeWidth="6"/>
                        <Circle radius="15" fill="transparent" stroke="#ffcc00" strokeWidth="6"/>
                    </Group>
                </graphic>
                <text>DVD</text>
            </Button>

        </HBox>
    </VBox>

    <Label AnchorPane.bottomAnchor="15"
           AnchorPane.rightAnchor="15"
           style="-fx-text-fill: #888888; -fx-font-size: 12px;">
        Version : 1.0
    </Label>
</AnchorPane>