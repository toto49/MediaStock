<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import java.net.URL?>
<AnchorPane xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx"
            fx:controller="com.eseo.mediastock.controller.LivresController"
            prefHeight="600.0" prefWidth="900.0"
            style="-fx-background-color: #2b2b2b;">

    <stylesheets>
        <URL value="@../../../../style/menu-deroulant.css"/>
        <URL value="@../../../../style/tableview.css"/>
    </stylesheets>

    <HBox alignment="CENTER_LEFT" spacing="20"
          AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0">

        <Button text="RETOUR" onAction="#ButtonReturn"
                style="-fx-background-color: transparent; -fx-text-fill: #ffcc00; -fx-border-color: #ffcc00; -fx-border-radius: 30; -fx-border-width: 2; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 8 20;">
            <graphic>
                <SVGPath content="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" fill="#ffcc00"
                         scaleX="0.8" scaleY="0.8"/>
            </graphic>
        </Button>

        <Label text="Bibliothèque (Livres)"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;">
            <effect>
                <DropShadow color="#00000066" radius="10" offsetY="3"/>
            </effect>
        </Label>

        <Region HBox.hgrow="ALWAYS" />

        <Button text="AJOUTER" onAction="#ButtonAjouter"
                style="-fx-background-color: transparent; -fx-text-fill: #ffcc00; -fx-border-color: #ffcc00; -fx-border-radius: 30; -fx-border-width: 2; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 8 20;">
            <graphic>
                <SVGPath content="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" fill="#ffcc00" scaleX="0.8" scaleY="0.8"/>
            </graphic>
        </Button>

    </HBox>

    <VBox alignment="TOP_CENTER" spacing="0"
          style="-fx-background-color: #383838; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 10, 0, 0, 5); -fx-padding: 10;"
          AnchorPane.topAnchor="90.0" AnchorPane.bottomAnchor="20.0"
          AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0">

        <TableView fx:id="tableLivres" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-background-insets: 0;">

            <columnResizePolicy>
                <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>

            <columns>
                <TableColumn text="#" fx:id="colId" minWidth="40" prefWidth="50" maxWidth="60"
                             style="-fx-alignment: CENTER;">
                    <cellValueFactory>
                        <PropertyValueFactory property="id"/>
                    </cellValueFactory>
                </TableColumn>

                <TableColumn text="Titre" fx:id="colTitre" prefWidth="250" minWidth="150"
                             style="-fx-font-weight: bold;">
                    <cellValueFactory>
                        <PropertyValueFactory property="titre"/>
                    </cellValueFactory>
                </TableColumn>

                <TableColumn text="Auteur" fx:id="colAuteur" prefWidth="180" minWidth="100">
                    <cellValueFactory>
                        <PropertyValueFactory property="auteur"/>
                    </cellValueFactory>
                </TableColumn>

                <TableColumn text="Éditeur" fx:id="colEditeur" prefWidth="150" minWidth="100">
                    <cellValueFactory>
                        <PropertyValueFactory property="editeur"/>
                    </cellValueFactory>
                </TableColumn>

                <TableColumn text="Année" fx:id="colAnnee" minWidth="60" prefWidth="80" maxWidth="90"
                             style="-fx-alignment: CENTER;">
                    <cellValueFactory>
                        <PropertyValueFactory property="anneeSortie"/>
                    </cellValueFactory>
                </TableColumn>

                <TableColumn text="ISBN" fx:id="colIsbn" prefWidth="130" minWidth="100">
                    <cellValueFactory>
                        <PropertyValueFactory property="isbn"/>
                    </cellValueFactory>
                </TableColumn>

                <TableColumn text="Pages" fx:id="colNbPages" minWidth="60" prefWidth="80" maxWidth="90"
                             style="-fx-alignment: CENTER;">
                    <cellValueFactory>
                        <PropertyValueFactory property="nbPages"/>
                    </cellValueFactory>
                </TableColumn>

                <TableColumn text="Format" fx:id="colFormat" prefWidth="110" minWidth="80"
                             style="-fx-alignment: CENTER;">
                    <cellValueFactory>
                        <PropertyValueFactory property="format"/>
                    </cellValueFactory>
                </TableColumn>

                <TableColumn fx:id="colAction" text="Actions" prefWidth="160" minWidth="140"
                             style="-fx-alignment: CENTER;"/>
            </columns>

            <placeholder>
                <VBox alignment="CENTER" spacing="10">
                    <ProgressIndicator fx:id="loadingIcon" prefWidth="40" prefHeight="40"/>
                    <Label fx:id="placeholderLabel" text="Recherche des LIVRES en cours..."
                           style="-fx-text-fill: #888; -fx-font-size: 14px;"/>
                </VBox>
            </placeholder>

        </TableView>

        <Pagination fx:id="paginationLivres" maxPageIndicatorCount="5" pageCount="1"
                    style="-fx-padding: 10 0 0 0;"/>
    </VBox>

</AnchorPane>